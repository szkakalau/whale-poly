DATABASE_URL=postgresql://whale:whale@postgres:5432/whale
# REDIS_URL is optional — leave empty for unified single-process mode (InMemoryRedis).
# Set to redis://redis:6379/0 for legacy multi-service mode with Celery workers.
REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO

TRADE_CREATED_QUEUE=trade_created
WHALE_TRADE_CREATED_QUEUE=whale_trade_created
ALERT_CREATED_QUEUE=alert_created

POLYMARKET_DATA_API_TRADES_URL=https://data-api.polymarket.com/trades
POLYMARKET_DATA_API_MARKETS_URL=https://gamma-api.polymarket.com/markets
HTTPS_PROXY=

WHALE_SINGLE_TRADE_USD_THRESHOLD=10000
WHALE_BUILD_USD_THRESHOLD=10000
WHALE_EXIT_USD_THRESHOLD=5000

ALERT_COOLDOWN_SECONDS=600
ALERT_MIN_SCORE=75
ALERT_MIN_TRADE_USD=1000
ALERT_ALWAYS_SCORE=85
ALERT_CONFIG_PATH=alert_engine_config.yaml

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYMENT_MODE=mock
LANDING_SUCCESS_URL=http://localhost:3000/success
LANDING_CANCEL_URL=http://localhost:3000/cancel
DEFAULT_CURRENCY=usd

TELEGRAM_BOT_TOKEN=
TELEGRAM_HEALTH_BOT_TOKEN=
TELEGRAM_HEALTH_CHAT_ID=
TELEGRAM_HEALTH_USERNAME=
BOT_USER_HASH_SECRET=
MOBILE_AUTH_SECRET=
ALERT_FANOUT_RATE_LIMIT_PER_MINUTE=20

NEXT_PUBLIC_SUBSCRIPTION_URL=/subscribe
NEXT_PUBLIC_FREE_SUBSCRIPTION_URL=/subscribe
PAYMENT_API_BASE_URL=http://payment-api:8014

# Google Play — Android subscription verification (Landing /api/mobile/billing/google/sync)
# Service account JSON with Android Publisher API access; link app in Play Console.
GOOGLE_PLAY_PACKAGE_NAME=com.sightwhale.android
# Either paste full JSON (escape quotes in shell) or use base64:
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# GOOGLE_PLAY_SERVICE_ACCOUNT_B64=

# ── Blog / Daily Article Generation ─────────────────────────────────────────
# Enable daily AI-generated blog article (EN + ZH) at 20:05 Beijing time.
# Set to "false" to disable. Uses real on-chain whale data as context.
BLOG_DAILY_ENABLED=true
# DeepSeek API key (also serves as admin key for blog API endpoints).
BLOG_LLM_API_KEY=
# DeepSeek-compatible API base URL. Defaults to https://api.deepseek.com/v1
BLOG_LLM_BASE_URL=https://api.deepseek.com/v1
# Model name. Defaults to deepseek-chat.
BLOG_LLM_MODEL=deepseek-chat

# ── Performance / Pooling (PF-M13) ────────────────────────────────────────────
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_MAX_CONNECTIONS=20
UVICORN_WORKERS=4
CELERY_WORKER_CONCURRENCY=4
WHALE_STATS_RAW_TRADE_CAP=100000
WHALE_STATS_HISTORY_CAP=100000
TRADE_CONSUME_BATCH=50
ALERT_CONSUME_BATCH_SIZE=10
CELERY_POOL=solo
CELERY_CONCURRENCY=1
ADMIN_TOKEN=
TELEGRAM_MINIAPP_SECRET=